{{ form_start(form) }}
    <label for="">Titre</label>
    {{ form_widget(form.title, {attr:{'class': 'form form-control'}}) }}
    <label for="">Auteur</label>
    {{ form_widget(form.author, {attr:{'class': 'form form-control'}}) }}
    <label for="">isbn</label>
    {{ form_widget(form.isbn, {attr:{'class': 'form form-control'}}) }}
    {% if button_label != 'Sauvegarder les modifications' %}
    <label for="">Stock</label>
    {{ form_widget(form.stock, {attr:{'class': 'form form-control'}}) }}
    {% endif %}
    <button class="btn btn-dark mt-4">{{ button_label|default('Sauvegarder') }}</button>
{{ form_end(form) }}
