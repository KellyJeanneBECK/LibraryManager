{% extends 'base.html.twig' %}

{% block title %}Book{% endblock %}

{% block body %}
    <section class="container">
        <h1>Livre</h1>

        <table class="table">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ book.id }}</td>
                </tr>
                <tr>
                    <th>Titre</th>
                    <td>{{ book.title }}</td>
                </tr>
                <tr>
                    <th>Auteur</th>
                    <td>{{ book.author }}</td>
                </tr>
                <tr>
                    <th>Isbn</th>
                    <td>{{ book.isbn }}</td>
                </tr>
                <tr>
                    <th>Stock</th>
                    <td>{{ book.stock }}</td>
                </tr>
            </tbody>
        </table>

        <a href="{{ path('app_book_index') }}" class="btn btn-secondary">Retour à la liste</a>

        <a href="{{ path('app_book_edit', {'id': book.id}) }}" class="btn btn-dark">Modifier</a>

        <a href="{{ path('app_book_stock_history', {'id': book.id}) }}" class="btn btn-outline-dark">Historique</a>

        {# {{ include('book/_delete_form.html.twig') }} #}
    </section>
{% endblock %}
